# ── MercadoPago (coworking E2; cursos pagos E3) ──
# En E1 no hay cobros: los cursos son gratuitos. MP se activa en E2 (coworking).
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ── WhatsApp / Twilio (E2) ───────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ── Claude API (tutor IA, asistente admin) ───────
ANTHROPIC_API_KEY=

# ── Sentry ───────────────────────────────────────
SENTRY_DSN=
